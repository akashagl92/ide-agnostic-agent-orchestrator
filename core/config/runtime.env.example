# Canonical PAI runtime configuration (portable, IDE-agnostic)
# This file is source-of-truth for mode vocabulary and capability toggles.

PROFILE=SHADOW
LOCKED=1
REASON=bootstrap_default_shadow

SUBAGENT_ENABLED=1
# Canonical modes: single_parent | proposal_only | scoped_write
SUBAGENT_MODE=proposal_only
SUBAGENT_MAX_CONCURRENCY=2
SUBAGENT_TIMEOUT_SEC=180
SUBAGENT_PARENT_ONLY_WRITES=1
SUBAGENT_NATIVE_WRITES=0
CAPABILITY_SPAWN_SUBAGENT=1

# Event bus settings
PAI_EVENT_BUS_ENABLED=1
PAI_EVENT_LOG=.pai/events/events.jsonl

# Policy settings
PAI_POLICY_ENABLED=1
PAI_POLICY_FILE=.pai/config/policy.json

# KPI window settings: rolling | lifetime
PAI_KPI_WINDOW_MODE=rolling
# Used when mode=rolling
PAI_KPI_WINDOW_SIZE=20
# Include reconciled stale jobs in KPI window: 0|1
PAI_KPI_INCLUDE_RECONCILED=0
# Refresh telemetry before quality evaluation: 0|1
PAI_QUALITY_REFRESH_TELEMETRY=1

# Native artifact race-condition mitigation controls
PAI_NATIVE_TIMEOUT_SEC=20
PAI_NATIVE_LOCK_TTL_SEC=120
PAI_NATIVE_LOCK_WAIT_SEC=30
PAI_NATIVE_BREAKER_THRESHOLD=2
PAI_NATIVE_BREAKER_COOLDOWN_SEC=300
PAI_NATIVE_RETRY_MAX=2
PAI_NATIVE_REPLAY_ENABLED=1
PAI_NATIVE_AUTO_SHADOW_ON_OPEN=1
PAI_NATIVE_QUEUE_ON_FAILURE=1
# Native artifact (task/implementation_plan/walkthrough) fallback automation
PAI_NATIVE_ARTIFACT_AUTO_FALLBACK_ENABLED=1
PAI_NATIVE_ARTIFACT_STALL_TIMEOUT_SEC=180
PAI_NATIVE_ARTIFACT_OBSERVE_ONLY=1
PAI_NATIVE_ARTIFACT_ONE_WAY_SHADOW=1
PAI_NATIVE_SHADOW_ENFORCE_BLOCK=1
# Native artifact bridge (for IDEs that persist artifacts as files, e.g. Antigravity)
PAI_NATIVE_ARTIFACT_BRIDGE_ENABLED=0
# Default source root; override per machine/IDE if needed.
PAI_NATIVE_ARTIFACT_SOURCE_ROOT=$HOME/.gemini/antigravity/brain
PAI_NATIVE_ARTIFACT_BRIDGE_POLL_SEC=5
PAI_NATIVE_ARTIFACT_BRIDGE_IDLE_END_SEC=30
# Auto-heal bridge on runtime/status bootstrap paths.
PAI_RUNTIME_AUTO_ENSURE_BRIDGE=1
# Canonical SHADOW orchestration artifact paths (comma-separated, no spaces)
PAI_SHADOW_ALLOWED_ARTIFACT_PATHS=.pai/tasks/todo.md,.pai/plans/active_plan.md,.pai/walkthrough-final.md

# Documentation/report rendering quality gate checks.
# all    = scan all tracked report files
# staged = scan staged report files only (recommended for pre-commit hooks)
PAI_DOCS_QUALITY_ENABLED=1
PAI_DOCS_QUALITY_SCOPE=all
