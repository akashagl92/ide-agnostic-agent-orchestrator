{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portable-pai-core/schemas/event.schema.json",
  "title": "Portable PAI Event",
  "type": "object",
  "required": ["ts", "event", "profile", "mode", "data"],
  "properties": {
    "ts": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*Z$"},
    "event": {"type": "string", "minLength": 1},
    "profile": {"type": "string", "enum": ["SHADOW", "NATIVE"]},
    "mode": {"type": "string", "enum": ["single_parent", "proposal_only", "scoped_write"]},
    "data": {"type": "object", "additionalProperties": {"type": "string"}}
  },
  "additionalProperties": false
}
